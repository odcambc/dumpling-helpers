{
  "name": "library-qc",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "workspaceFolder": "/workspaces/library-qc",
  "remoteUser": "vscode",

  // Pick ports that don't collide with the dumpling-helpers devcontainer
  // (which uses 8000 / 5173).
  "forwardPorts": [8770, 5273],
  "portsAttributes": {
    "8770": { "label": "library-qc API", "onAutoForward": "silent" },
    "5273": { "label": "library-qc web", "onAutoForward": "openBrowser" }
  },

  "postCreateCommand": "npm install && npm install --prefix frontend && cd backend && uv sync",
  "postStartCommand": "sudo /workspaces/library-qc/.devcontainer/init-firewall.sh || true",

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "bradlc.vscode-tailwindcss",
        "ms-python.python",
        "charliermarsh.ruff"
      ]
    }
  }
}
