# Copy to deploy/.env on the VPS and fill in real values.
# Caddy reads these via `EnvironmentFile` in /etc/caddy/Caddyfile.env
# (the bootstrap script wires the link).

# Public hostnames — one per tool — must match the Cloudflare proxied DNS
# records. All three are covered by the single *.<domain> origin certificate.
# TODO(user): set these to the real proxied hostnames.
DUMPLING_HOST=dumpling.example.com
FUSILLI_HOST=fusilli.example.com
STROMBOLI_HOST=stromboli.example.com

# ── Cross-tool links (BUILD-TIME) ──────────────────────────────────────────
# The SOUS-CHEF "Switch tool" menu links between the three apps. Because they
# live on separate origins, each frontend must be built knowing the others'
# URLs. Vite inlines these at build time, so they must be present in the
# environment when `npm run build` runs (they are NOT read by Caddy at runtime).
# Unset → the apps fall back to localhost:5173/5174/5175 (dev only).
# TODO(user): set these to the real https URLs (match the *_HOST values above).
VITE_DUMPLING_URL=https://dumpling.example.com
VITE_FUSILLI_URL=https://fusilli.example.com
VITE_STROMBOLI_URL=https://stromboli.example.com
