[Unit]
Description=Dumpling library-qc API (FastAPI/uvicorn)
After=network-online.target
Wants=network-online.target

[Service]
Type=exec
User=dumpling
Group=dumpling
WorkingDirectory=/srv/dumpling-helpers/library-qc/backend
Environment=PYTHONUNBUFFERED=1
Environment=UV_CACHE_DIR=/home/dumpling/.cache/uv
Environment=ALLOWED_ORIGINS=https://library-qc.example.com
ExecStart=/usr/local/bin/uv run uvicorn app.main:app --host 127.0.0.1 --port 8001
Restart=on-failure
RestartSec=3
# Hardening
NoNewPrivileges=true
ProtectSystem=strict
ProtectHome=read-only
ReadWritePaths=/home/dumpling/.cache/uv /srv/dumpling-helpers/library-qc/backend
PrivateTmp=true

[Install]
WantedBy=multi-user.target
