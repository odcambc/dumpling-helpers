{
  "name": "dumpling-helpers",

  "image": "mcr.microsoft.com/devcontainers/python:3.13-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "lts" },
    "ghcr.io/devcontainers/features/git:1": {}
  },

  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",

  // Forward the suite: API (8000) and UI (5173).
  "forwardPorts": [8000, 5173],
  "portsAttributes": {
    "8000": { "label": "API", "onAutoForward": "silent" },
    "5173": { "label": "UI",  "onAutoForward": "openBrowser" }
  },

  "remoteUser": "vscode",

  "postCreateCommand": "curl -LsSf https://astral.sh/uv/install.sh | sh && export PATH=\"$HOME/.local/bin:$PATH\" && cd /workspace && npm run install:all",

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "dbaeumer.vscode-eslint",
        "bradlc.vscode-tailwindcss"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "python.defaultInterpreterPath": "/workspace/backend/.venv/bin/python",
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        }
      }
    }
  }
}
